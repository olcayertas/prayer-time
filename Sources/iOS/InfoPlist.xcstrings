    "NSLocationWhenInUseUsageDescription" : {
      "comment" : "System location-permission prompt: prayer times for the current city + the Qibla compass",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يستخدم تطبيق أوقات الصلاة موقعك لعرض أوقات الصلاة لمكانك ولتوجيه بوصلة القبلة نحو الكعبة في مكة."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prayer Times uses your location to show prayer times for where you are and to point the Qibla compass toward the Kaaba in Mecca."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Namaz Vakti, bulunduğunuz yerin namaz vakitlerini göstermek ve Kıble pusulasını Kâbe'ye yöneltmek için konumunuzu kullanır."
          }
        }
      }
    }
